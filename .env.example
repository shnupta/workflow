# GitHub personal access token — needed for PR analysis
# Generate at: https://github.com/settings/tokens (needs repo scope)
GITHUB_TOKEN=

# Anthropic API key — needed for PR analysis
ANTHROPIC_API_KEY=

# Claude model to use for PR analysis (default: claude-opus-4-5)
# Thinking is enabled automatically for claude-3-7-* and claude-opus-4-* models
CLAUDE_MODEL=claude-opus-4-6

# Override the Claude API base URL (default: https://api.anthropic.com)
# Useful if routing through a proxy or using a different API-compatible provider
CLAUDE_BASE_URL=
